# --- LLM provider: "ollama" (local, free) | "kimi" (Kimi Code subscription)
# ---                | "openai" | "anthropic"
AEGIS_LLM_PROVIDER=ollama

# --- Kimi Code subscription (billed via your membership, not per-token) ---
# Create a key in the Kimi Code Console: https://www.kimi.com/code
KIMI_API_KEY=
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# Models by tier: kimi-for-coding (all members) | k3 (Moderato+) |
#                 kimi-for-coding-highspeed (Allegretto+)

# --- API keys (fill the one matching your provider) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Model names ---
AEGIS_ATTACK_MODEL=llama3.1:8b        # attack agents (local & free via Ollama)
AEGIS_JUDGE_MODEL=llama3.1:8b         # evaluator / judge (use a stronger model if available)
# AEGIS_ATTACK_MODEL=kimi-for-coding  # with AEGIS_LLM_PROVIDER=kimi
# AEGIS_JUDGE_MODEL=k3
# AEGIS_ATTACK_MODEL=gpt-4o-mini      # OpenAI alternative
# AEGIS_JUDGE_MODEL=gpt-4o
# AEGIS_ATTACK_MODEL=claude-haiku-4-5-20251001
# AEGIS_JUDGE_MODEL=claude-sonnet-4-6

# --- Zero-AI demo mode: no Ollama, no API key needed ---
# Scripted attacks only + heuristic judge. Set to false for full agentic mode.
AEGIS_SCRIPTED_MODE=false

# --- Safety scope (mandatory): only these targets may be attacked ---
# Comma-separated list of allowed target URLs/hosts. Everything else is refused.
AEGIS_TARGET_WHITELIST=http://localhost:8100,http://localhost:8101
# Add YOUR OWN apps here to audit them, e.g.:
# AEGIS_TARGET_WHITELIST=http://localhost:8100,https://readplay.fr,https://strikerfps.xyz

# --- Generic target adapter (for auditing any app, not just the demo target) ---
# AEGIS_TARGET_CHAT_PATH=/api/chat          # endpoint path (default /chat)
# AEGIS_TARGET_REQUEST_FIELD=message        # JSON field carrying the user message
# AEGIS_TARGET_RESPONSE_FIELD=reply         # dot-path to the reply in the response
# AEGIS_TARGET_HEALTH_PATH=                 # empty = skip health check
# AEGIS_TARGET_HEADERS=Authorization:Bearer xxx   # auth headers if your app needs them

# --- Observability (optional, milestone 6) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
